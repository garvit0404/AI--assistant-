{
  "name": "ai-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "AI Assistant Monorepo",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:all": "npm run build --workspaces --if-present",
    "dev:all": "npm run dev --workspaces --parallel",
    "docker:up": "docker-compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infra/docker/docker-compose.yml down",
    "docker:rebuild": "docker-compose -f infra/docker/docker-compose.yml up -d --build",
    "clean": "npm run clean --workspaces --if-present && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
