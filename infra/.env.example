# ============================================================
# AI-Assistant - Environment Examples (Template)
# ============================================================

# --- API Server ---
PORT=3000
NODE_ENV=development

# --- Core Databases ---
# Use the internal service names when running in Docker
MONGO_URL=mongodb://ai_mongodb:27017/ai_os
REDIS_URL=redis://ai_redis:6379

# --- AI Configuration ---
# Options: "mock" (offline logic) or "live" (real LLM)
AI_MODE=mock
AI_EXECUTION_MODE=mock

# IMPORTANT: Never commit your real sk-... keys to GitHub!
OPENAI_API_KEY=sk-placeholder-replace-with-your-real-key
OPENAI_MODEL=gpt-4o

# --- Notification Hooks (Optional) ---
TELEGRAM_BOT_TOKEN=123456:placeholder
TELEGRAM_CHAT_ID=00000000
